# pnpm 11 runs an install pre-check before `pnpm run`; with security-gated build scripts
# (sharp / unrs-resolver) that pre-check exits non-zero. We allowlist those builds in
# pnpm-workspace.yaml, but also skip the redundant pre-check so `pnpm build` is deterministic
# (local + Docker builder stage).
verify-deps-before-run=false

# ============================================================================
# Yahaha 平台 — 环境变量契约
# 复制为 .env 后填值。请勿提交真实密钥。无 MODEL_API_KEY 时系统以 mock 模式跑通。
# 名称/用途为契约的一部分，新增变量须同时更新本文件与 docs/。
# ============================================================================

# ---- 应用 ----
# 浏览器可见的应用源（用于 CORS allow-origin、回调、绝对链接）
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Node 运行环境
NODE_ENV=development

# ---- 数据库 (PostgreSQL) ----
# Prisma 连接串。compose 内主机名为服务名 db；本地裸跑用 localhost
DATABASE_URL=postgresql://yahaha:yahaha@localhost:5432/yahaha?schema=public

# ---- 队列 (Redis / BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- 对象存储 (S3 兼容 / MinIO) ----
# 服务端访问 MinIO 的内网端点。此处 localhost 值仅用于本机裸跑；docker compose 会注入
# http://minio:9000（服务名）覆盖它。S3_PUBLIC_ENDPOINT 则始终是浏览器可达的 localhost。
S3_ENDPOINT=http://localhost:9000
# 浏览器/Play 访问产物的公开端点；必须与 app 跨域（这是隔离与"证明远端"的关键）
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=yahaha
# MinIO 必须为 true（path-style）；切到真实 AWS S3 时置 false 即可，无需改代码
S3_FORCE_PATH_STYLE=true

# ---- 鉴权 (NextAuth / Auth.js v5) ----
# openssl rand -base64 32 生成；勿用示例值上线（compose 缺省注入一个 dev secret，可被本文件覆盖）
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
# Docker / 反代后置时需为 true，否则 Auth.js 报 UntrustedHost
AUTH_TRUST_HOST=true

# ---- 模型服务 (可插拔；缺省 mock 可离线复现) ----
# codex | openai | anthropic | mock
MODEL_PROVIDER=mock
# OpenAI 兼容端点（Yahaha GPT-5.5 / Codex 接入填这里）
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=gpt-5.5
# 多模态 ingest 用的视觉模型；留空则跳过 vision、退化为纯文本 ingest
VISION_MODEL_NAME=gpt-5.5

# ---- 第三方登录 (可选；env-gated，配齐某 provider 的 id+secret 即真跑通其登录与账号绑定) ----
# 缺省留空 → 该 provider 不注册，登录页只显示邮箱登录（红线⑤：无密钥也能跑）。勿提交真凭据。
# 回调 URL（在 Google/GitHub OAuth App 里登记）：
#   Google → ${AUTH_URL}/api/auth/callback/google
#   GitHub → ${AUTH_URL}/api/auth/callback/github
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- 资源限额 / 安全阈值 ----
# 单个上传素材最大字节（默认 10MB）
MAX_UPLOAD_BYTES=10485760
# 单次生成任务总超时（毫秒，防止卡在 running）
GENERATION_TIMEOUT_MS=180000
# 单个 Agent 节点瞬时失败的最大重试次数
MAX_AGENT_RETRIES=2
# 生成产物 bundle 最大字节（防止超大 / 失控产物）
MAX_BUNDLE_BYTES=2097152
# worker 同时处理的生成任务数（BullMQ 并发上限，防过载）
WORKER_CONCURRENCY=2
# per-user 新建生成任务的速率限额：每窗口最多次数 + 窗口秒数（Redis 固定窗口，fail-open）
RATE_LIMIT_TASKS=10
RATE_LIMIT_WINDOW_SEC=60
# 公开埋点 /api/play-events 每窗口每 (uid|IP) 上限（防刷 playCount）
RATE_LIMIT_PLAY_EVENTS=30
# 生成成本统计：token → 估算美元单价（每 1k token，默认 0.01；mock token 为估算值）
COST_USD_PER_1K_TOKENS=0.01
